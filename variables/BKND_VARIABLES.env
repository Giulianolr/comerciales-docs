# ══════════════════════════════════════════════════════════════════════════════
# REGISTRO DE VARIABLES — BACKEND
# Sistema de Inventario Dinámico - Locales Comerciales Chile
#
# Prefijo identificador : BKND_
# Repo de origen        : comerciales-backend
# Archivo fuente        : app/core/config.py + .env.example
# Fecha                 : 2026-04-12
#
# USO:
#   Este archivo es el registro central de todas las variables del backend.
#   NO se usa directamente como .env. Para levantar el backend, copiar
#   comerciales-backend/.env.example → comerciales-backend/.env
#   y completar los valores reales.
# ══════════════════════════════════════════════════════════════════════════════


# ── APLICACIÓN ────────────────────────────────────────────────────────────────
# Nombre visible de la aplicación
BKND_APP_NAME="Comerciales Backend"

# Clave secreta de la API (usar para firmar tokens o proteger endpoints internos)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
BKND_API_KEY=changeme_generate_a_secret_key


# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
# Conexión PostgreSQL
# Formato: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Docker local : postgresql://comerciales:comerciales_dev@db:5432/comerciales
# GCP Cloud SQL: postgresql://comerciales:<pwd>@/<dbname>?host=/cloudsql/<instance>
BKND_DATABASE_URL=postgresql://comerciales:comerciales_dev@db:5432/comerciales


# ── REDIS / CELERY ────────────────────────────────────────────────────────────
# URL de conexión a Redis (broker y backend de resultados para Celery)
# Docker local : redis://redis:6379/0
# GCP Memorystore: redis://<ip>:6379/0
BKND_REDIS_URL=redis://redis:6379/0


# ── SMTP — CORREO ─────────────────────────────────────────────────────────────
# Servidor SMTP para envío de alertas y reportes automáticos
BKND_SMTP_HOST=smtp.gmail.com
BKND_SMTP_PORT=587

# Cuenta remitente (usar contraseña de aplicación Gmail, no la contraseña real)
BKND_SMTP_USER=tu_correo@gmail.com
BKND_SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Dirección visible en el campo "De:" de los correos enviados
BKND_SMTP_FROM=noreply@comerciales.cl


# ── DESTINATARIOS DE ALERTAS ─────────────────────────────────────────────────
# Correos que reciben alertas de stock bajo, ventas altas y reportes diarios
BKND_EMAIL_GERENCIA=gerencia@comerciales.cl
BKND_EMAIL_ADMIN=admin@comerciales.cl
BKND_EMAIL_SUPERVISOR=supervisor@comerciales.cl


# ── REGLAS DE NEGOCIO ────────────────────────────────────────────────────────
# Monto en CLP a partir del cual se envía alerta de "venta alta" (WF01)
BKND_ALERTA_VENTA_ALTA_CLP=50000


# ── AI — MISTRAL OCR + GOOGLE GEMINI (WF05) ──────────────────────────────────
# Usadas en el router de importación de facturas por imagen
# Obtener en: https://console.mistral.ai / https://aistudio.google.com
BKND_MISTRAL_API_KEY=
BKND_GOOGLE_API_KEY=


# ── AI — OPENAI VISION (WF06) ────────────────────────────────────────────────
# Alternativa a Mistral/Gemini para OCR de facturas
# Obtener en: https://platform.openai.com/api-keys
BKND_OPENAI_API_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# TABLA DE REFERENCIA RÁPIDA
#
# Variable BKND_               | Nombre real en .env     | Tipo     | Requerida
# ─────────────────────────────┼─────────────────────────┼──────────┼──────────
# BKND_APP_NAME                | APP_NAME                | string   | No
# BKND_API_KEY                 | API_KEY                 | string   | Sí
# BKND_DATABASE_URL            | DATABASE_URL            | string   | Sí
# BKND_REDIS_URL               | REDIS_URL               | string   | Sí
# BKND_SMTP_HOST               | SMTP_HOST               | string   | No
# BKND_SMTP_PORT               | SMTP_PORT               | integer  | No
# BKND_SMTP_USER               | SMTP_USER               | string   | No
# BKND_SMTP_PASSWORD           | SMTP_PASSWORD           | string   | No
# BKND_SMTP_FROM               | SMTP_FROM               | string   | No
# BKND_EMAIL_GERENCIA          | EMAIL_GERENCIA          | string   | No
# BKND_EMAIL_ADMIN             | EMAIL_ADMIN             | string   | No
# BKND_EMAIL_SUPERVISOR        | EMAIL_SUPERVISOR        | string   | No
# BKND_ALERTA_VENTA_ALTA_CLP   | ALERTA_VENTA_ALTA_CLP  | integer  | No
# BKND_MISTRAL_API_KEY         | MISTRAL_API_KEY         | string   | No *
# BKND_GOOGLE_API_KEY          | GOOGLE_API_KEY          | string   | No *
# BKND_OPENAI_API_KEY          | OPENAI_API_KEY          | string   | No *
#
# * Requerida solo si se activan los workflows WF05/WF06 de importación de facturas AI
# ══════════════════════════════════════════════════════════════════════════════
