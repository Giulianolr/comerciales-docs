# ══════════════════════════════════════════════════════════════════════════════
# REGISTRO DE VARIABLES — FRONTEND
# Sistema de Inventario Dinámico - Locales Comerciales Chile
#
# Prefijo identificador : FRNT_
# Repo de origen        : comerciales-frontend
# Archivo fuente        : .env.example + vite.config.ts
# Fecha                 : 2026-04-12
#
# IMPORTANTE — Convención Vite:
#   Vite solo expone al navegador las variables que comienzan con VITE_
#   El prefijo FRNT_ es para identificación en este registro central.
#   En el .env real del proyecto, el nombre real es el que aparece en la
#   columna "Nombre real en .env" de la tabla al final del archivo.
#
# USO:
#   Este archivo es el registro central de todas las variables del frontend.
#   NO se usa directamente como .env. Para levantar el frontend, copiar
#   comerciales-frontend/.env.example → comerciales-frontend/.env
#   y completar los valores reales.
# ══════════════════════════════════════════════════════════════════════════════


# ── API / CONEXIÓN AL BACKEND ─────────────────────────────────────────────────
# URL base de la API REST del backend FastAPI
# Desarrollo local  : http://localhost:8000/api
# Staging / Prod    : https://api.comerciales.cl/api  (o IP del VPS)
FRNT_API_BASE_URL=http://localhost:8000/api

# URL del WebSocket para actualizaciones en tiempo real (stock, preboletas)
# Desarrollo local  : ws://localhost:8000/ws
# Staging / Prod    : wss://api.comerciales.cl/ws
FRNT_WS_URL=ws://localhost:8000/ws


# ── CONFIGURACIÓN DE LA APLICACIÓN ───────────────────────────────────────────
# Título visible en la pestaña del navegador y en el header del dashboard
FRNT_APP_TITLE=Panel Gerente - Comerciales

# Versión del frontend (se muestra en el footer o en /about)
FRNT_APP_VERSION=0.1.0


# ── FEATURE FLAGS ────────────────────────────────────────────────────────────
# Activa el módulo de analíticas (gráficos avanzados, ApexCharts)
# true  = activo | false = oculto
FRNT_ENABLE_ANALYTICS=true

# Activa datos mock en lugar de llamadas reales al backend
# true  = usar mocks (desarrollo sin backend)
# false = usar API real (integración con backend)
FRNT_ENABLE_MOCK_DATA=true


# ── CONFIGURACIÓN DEL DEV SERVER (vite.config.ts) ────────────────────────────
# Puerto en que corre el servidor de desarrollo Vite
# No se define como variable de entorno — está hardcoded en vite.config.ts
# Valor actual: 5173
# Para cambiar: editar comerciales-frontend/vite.config.ts → server.port

# Proxy de desarrollo: redirige /api → VITE_API_BASE_URL
# Configurado en vite.config.ts, no requiere variable adicional


# ══════════════════════════════════════════════════════════════════════════════
# TABLA DE REFERENCIA RÁPIDA
#
# Variable FRNT_               | Nombre real en .env     | Tipo     | Requerida
# ─────────────────────────────┼─────────────────────────┼──────────┼──────────
# FRNT_API_BASE_URL            | VITE_API_BASE_URL       | string   | Sí
# FRNT_WS_URL                  | VITE_WS_URL             | string   | No *
# FRNT_APP_TITLE               | VITE_APP_TITLE          | string   | No
# FRNT_APP_VERSION             | VITE_APP_VERSION        | string   | No
# FRNT_ENABLE_ANALYTICS        | VITE_ENABLE_ANALYTICS   | boolean  | No
# FRNT_ENABLE_MOCK_DATA        | VITE_ENABLE_MOCK_DATA   | boolean  | No
#
# * Requerida cuando se implemente el módulo de WebSocket (actualizaciones en tiempo real)
#
# VARIABLES INTERNAS DE VITE (no configurables por .env):
# BASE_URL  — ruta base de la app, usada en router/index.ts (import.meta.env.BASE_URL)
#             se define en vite.config.ts → base (default: "/")
# MODE      — "development" | "production" (automático según el comando)
# DEV       — true en desarrollo (automático)
# PROD      — true en producción (automático)
# ══════════════════════════════════════════════════════════════════════════════
